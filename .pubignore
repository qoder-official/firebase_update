# Build artifacts and caches — not part of the published package
build/
.dart_tool/

# Firebase RC tool — standalone dev tool with its own pubspec, not part of the package
tool/
test/firebase_config/
documentation/

# Live RC integration test — requires project-specific credentials, not runnable by consumers
example/integration_test/live_rc_test.dart

# Firebase project config files — contain project-specific API keys
# Consumers generate their own via `flutterfire configure`
example/lib/firebase_options.dart
example/android/app/google-services.json
example/ios/Runner/GoogleService-Info.plist
